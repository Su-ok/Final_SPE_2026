pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "siddheshmahajan/finshield-api"
        DOCKER_TAG   = "${BUILD_NUMBER}"
        VAULT_ADDR   = "http://host.docker.internal:8200"
        VAULT_TOKEN  = "finshield-root-token"
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        timestamps()
    }

    stages {
        // =======================================================
        // 1. PREPARATION
        // =======================================================
        stage('Preparation') {
            steps {
                echo "🏗️  Starting FinShield Pipeline for Build #${DOCKER_TAG}"
                checkout scm
            }
        }

        // =======================================================
        // 2. BUILD IMAGE
        // =======================================================
        stage('Build Image') {
            steps {
                sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} -t ${DOCKER_IMAGE}:latest ./app/backend"
                echo "✅ Built ${DOCKER_IMAGE}:${DOCKER_TAG}"
            }
        }

        // =======================================================
        // 3. UNIT TESTS
        // =======================================================
        stage('Unit Tests') {
            steps {
                sh """
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r app/backend/requirements.txt pytest
                    pytest app/backend/tests
                """
            }
        }

        // =======================================================
        // 4. SECURITY SCAN (TRIVY)
        // =======================================================
        stage('Security Scan') {
            steps {
                sh """
                    set +e
                    if command -v trivy > /dev/null 2>&1; then
                        trivy image --exit-code 0 --severity HIGH,CRITICAL \
                            --format table ${DOCKER_IMAGE}:${DOCKER_TAG}
                    else
                        echo "⚠️  Trivy not installed, skipping image scan."
                    fi
                    set -e
                """
            }
        }

        // =======================================================
        // 5. PUSH TO DOCKER HUB
        // =======================================================
        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', usernameVariable: 'DOCKERHUB_USER', passwordVariable: 'DOCKERHUB_PASS')]) {
                    sh """
                        echo \$DOCKERHUB_PASS | docker login -u \$DOCKERHUB_USER --password-stdin
                        docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
                        docker push ${DOCKER_IMAGE}:latest
                        echo "✅ Pushed ${DOCKER_IMAGE}:${DOCKER_TAG} to Docker Hub"
                        docker logout
                    """
                }
            }
        }

        // =======================================================
        // 6. CONFIGURATION AUDIT (ANSIBLE)
        // =======================================================
        stage('Configuration Audit') {
            steps {
                echo '📋 Starting Ansible Environment Audit...'
                sh 'ansible-playbook -i "localhost," -c local devops/ansible/playbooks/audit.yml'
            }
        }

        // =======================================================
        // 7. DEPLOY TO KUBERNETES
        // =======================================================
        stage('Kubernetes Deploy') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh """
                        # Download kubectl if missing
                        if ! command -v kubectl > /dev/null 2>&1; then
                            echo "Installing kubectl..."
                            curl -LO "https://dl.k8s.io/release/v1.28.0/bin/linux/amd64/kubectl"
                            chmod +x kubectl
                            KUBECTL_CMD="./kubectl"
                        else
                            KUBECTL_CMD="kubectl"
                        fi

                        # Update manifest with correct tag
                        sed -i "s|IMAGE_TAG|${DOCKER_TAG}|g" devops/kubernetes/deployment.yaml

                        # Bridge Minikube network gap (Final Solution)
                        # This replaces whatever IP Minikube has with the 'minikube' hostname
                        sed -i -E "s|https://[0-9.]+:|https://minikube:|g" \$KUBECONFIG
                        echo "Configured kubeconfig to use 'minikube' hostname"

                        # Deploy
                        \$KUBECTL_CMD --kubeconfig=\$KUBECONFIG apply -f devops/kubernetes/deployment.yaml
                        \$KUBECTL_CMD --kubeconfig=\$KUBECONFIG apply -f devops/kubernetes/service.yaml
                        \$KUBECTL_CMD --kubeconfig=\$KUBECONFIG apply -f devops/kubernetes/hpa.yaml
                        echo "✅ Deployment updated in Minikube"
                    """
                }
            }
        }
    }

    post {
        success {
            echo """
            ╔══════════════════════════════════════════╗
            ║  ✅ FinShield Pipeline SUCCESS            ║
            ║  Build #${DOCKER_TAG} deployed      ║
            ╚══════════════════════════════════════════╝
            """
            sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} || true"
        }
        failure {
            echo "❌ Pipeline failed at stage. Check logs above."
            sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} || true"
        }
        always {
            cleanWs()
        }
    }
}
