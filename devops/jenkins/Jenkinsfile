// FinShield — Jenkins CI/CD Pipeline
// Triggers on GitHub push → Build → Test → Docker Push → Deploy

pipeline {
    agent any

    environment {
        APP_NAME        = "finshield-api"
        DOCKERHUB_USER  = "siddheshmahajan"

        // Build number tag
        DOCKER_TAG      = "${env.BUILD_NUMBER}"

        // Vault Configuration
        VAULT_ADDR      = "http://vault:8200"

        // TEMPORARY FOR TESTING
        // Later replace with:
        // credentials('vault-root-token')
        VAULT_TOKEN     = "root"

        KUBECONFIG_PATH = "/var/jenkins_home/.kube/config"
    }

    triggers {
        githubPush()
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ─────────────────────────────────────────────────────────────
        stage('📥 Checkout') {
        // ─────────────────────────────────────────────────────────────
            steps {
                echo "🔍 Checking out source from GitHub..."
                checkout scm
                sh "git log --oneline -5"
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('⚙️ Prepare Variables') {
        // ─────────────────────────────────────────────────────────────
            steps {
                script {
                    env.DOCKER_IMAGE = "${env.DOCKERHUB_USER}/${env.APP_NAME}"
                }

                echo "Docker Image: ${env.DOCKER_IMAGE}"
                echo "Docker Tag: ${env.DOCKER_TAG}"
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('🔐 Vault Secret Pull') {
        // ─────────────────────────────────────────────────────────────
            steps {
                script {
                    env.DOCKERHUB_PASS = sh(
                        script: '''
                            curl -s -H "X-Vault-Token: $VAULT_TOKEN" \
                            $VAULT_ADDR/v1/secret/data/finshield/dockerhub \
                            | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['data']['password'])"
                        ''',
                        returnStdout: true
                    ).trim()
                }

                echo "Vault secret pull complete ✅"
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('🧪 Run Automated Tests') {
        // ─────────────────────────────────────────────────────────────
            steps {
                sh """
                    cd app/backend

                    pip install -r requirements.txt --quiet
                    pip install pytest httpx --quiet

                    cd ../..

                    python -m pytest app/tests/ \
                        -v \
                        --tb=short \
                        --junitxml=test-results.xml
                """
            }

            post {
                always {
                    junit 'test-results.xml'
                }

                failure {
                    echo "❌ Tests failed! Aborting pipeline."
                }
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('🐳 Build Docker Image') {
        // ─────────────────────────────────────────────────────────────
            steps {
                sh """
                    echo "Building Docker image: ${DOCKER_IMAGE}:${DOCKER_TAG}"

                    docker build \
                        --build-arg APP_VERSION=${DOCKER_TAG} \
                        -t ${DOCKER_IMAGE}:${DOCKER_TAG} \
                        -t ${DOCKER_IMAGE}:latest \
                        app/backend/

                    docker images | grep ${APP_NAME}
                """
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('🔒 Security Scan (Trivy)') {
        // ─────────────────────────────────────────────────────────────
            steps {
                sh """
                    if command -v trivy > /dev/null 2>&1; then

                        trivy image \
                            --exit-code 0 \
                            --severity HIGH,CRITICAL \
                            --format table \
                            ${DOCKER_IMAGE}:${DOCKER_TAG}

                    else
                        echo "⚠️ Trivy not installed, skipping scan"
                    fi
                """
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('📤 Push to Docker Hub') {
        // ─────────────────────────────────────────────────────────────
            steps {
                sh """
                    echo \$DOCKERHUB_PASS | docker login \
                        -u ${DOCKERHUB_USER} \
                        --password-stdin

                    docker push ${DOCKER_IMAGE}:${DOCKER_TAG}

                    docker push ${DOCKER_IMAGE}:latest

                    echo "✅ Docker image pushed successfully"

                    docker logout
                """
            }
        }

        /*
        // ─────────────────────────────────────────────────────────────
        stage('⚙️ Ansible Deploy') {
        // ─────────────────────────────────────────────────────────────
            steps {
                sh """
                    cd devops/ansible

                    ansible-playbook \
                        -i inventory/hosts.yml \
                        playbooks/deploy.yml \
                        --extra-vars "docker_tag=${DOCKER_TAG}" \
                        -v
                """
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('☸️ Kubernetes Deploy') {
        // ─────────────────────────────────────────────────────────────
            steps {
                withCredentials([
                    file(
                        credentialsId: 'kubeconfig',
                        variable: 'KUBECONFIG'
                    )
                ]) {

                    sh """
                        sed -i \
                        "s|IMAGE_TAG|${DOCKER_TAG}|g" \
                        devops/kubernetes/deployment.yaml

                        kubectl apply -f devops/kubernetes/deployment.yaml

                        kubectl apply -f devops/kubernetes/service.yaml

                        kubectl apply -f devops/kubernetes/hpa.yaml

                        kubectl rollout status \
                            deployment/finshield-api \
                            --timeout=120s

                        kubectl get pods -l app=finshield-api
                    """
                }
            }
        }

        // ─────────────────────────────────────────────────────────────
        stage('📊 Smoke Test') {
        // ─────────────────────────────────────────────────────────────
            steps {
                sh """
                    sleep 5

                    curl -sf \
                    http://finshield-api:8000/health

                    echo "✅ Smoke test completed"
                """
            }
        }
        */
    }

    post {

        success {
            echo """
╔══════════════════════════════════════════╗
║  ✅ FinShield Pipeline SUCCESS          ║
║  Build #${env.BUILD_NUMBER} deployed    ║
╚══════════════════════════════════════════╝
"""
        }

        failure {
            echo "❌ Pipeline failed at stage. Check logs above."
        }

        always {

            script {
                if (env.DOCKER_IMAGE && env.DOCKER_TAG) {

                    sh """
                        docker rmi \
                        ${DOCKER_IMAGE}:${DOCKER_TAG} || true
                    """
                }
            }

            cleanWs()
        }
    }
}
