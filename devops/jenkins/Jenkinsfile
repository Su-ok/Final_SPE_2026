// FinShield — Jenkins CI/CD Pipeline
// Triggers on GitHub push → Build → Test → Docker Push → Deploy

pipeline {
    agent any

    environment {
        APP_NAME        = "finshield-api"
        DOCKERHUB_USER  = "siddheshmahajan"
        DOCKER_TAG      = "${env.BUILD_NUMBER}"
        VAULT_ADDR      = "http://vault:8200"
        VAULT_TOKEN     = "finshield-root-token"
        KUBECONFIG_PATH = "/var/jenkins_home/.kube/config"
    }

    triggers {
        pollSCM('* * * * *') // Check GitHub for changes every single minute
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ─────────────────────────────────────────────────────────────────────
        stage('📥 Checkout') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                echo "🔍 Checking out source from GitHub..."
                checkout scm
                sh "git log --oneline -5"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('⚙️ Prepare Variables') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                script {
                    env.DOCKER_IMAGE = "${env.DOCKERHUB_USER}/${env.APP_NAME}"
                }
                echo "Docker Image: ${env.DOCKER_IMAGE}"
                echo "Docker Tag: ${env.DOCKER_TAG}"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('🔐 Vault Secret Pull') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                script {
                    echo "Detecting Vault connection..."
                    env.DOCKERHUB_PASS = sh(
                        script: """
                            set +e
                            # Try multiple possible hostnames
                            for host in vault finshield-v3-vault-1 finshield-vault; do
                                response=\$(curl -s --connect-timeout 2 -H "X-Vault-Token: ${VAULT_TOKEN}" http://\$host:8200/v1/secret/data/finshield/dockerhub)
                                if [ ! -z "\$response" ] && echo "\$response" | grep -q "data"; then
                                    echo "✅ Connected to \$host"
                                    echo "\$response" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['data']['password'])"
                                    exit 0
                                fi
                            done
                            echo "❌ ERROR: Could not reach Vault on any known hostname."
                            exit 1
                        """,
                        returnStdout: true
                    ).trim().split('\n')[-1] 
                }
                echo "Vault secret pull complete ✅"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('🧪 Run Automated Tests') {

    steps {

        sh """

            cd app/backend

            # Create virtual environment
            python3 -m venv venv

            # Activate venv
            . venv/bin/activate

            # Upgrade pip
            pip install --upgrade pip

            # Install dependencies
            pip install -r requirements.txt

            pip install pytest httpx

            cd ../..

            # Run tests
            app/backend/venv/bin/python -m pytest \
                app/tests/ \
                -v \
                --tb=short \
                --junitxml=test-results.xml

        """
    }

    post {

        always {

            junit(
                allowEmptyResults: true,
                testResults: 'test-results.xml'
            )
        }

        failure {

            echo "❌ Tests failed! Aborting pipeline."
        }
    }
}

        // ─────────────────────────────────────────────────────────────────────
        stage('🐳 Build Docker Image') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                sh """
                    echo "Building Docker image: ${DOCKER_IMAGE}:${DOCKER_TAG}"
                    docker build \
                        --build-arg APP_VERSION=${DOCKER_TAG} \
                        -t ${DOCKER_IMAGE}:${DOCKER_TAG} \
                        -t ${DOCKER_IMAGE}:latest \
                        app/backend/
                    docker images | grep ${APP_NAME}
                """
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('🔒 Security Scan (Trivy)') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                sh """
                    set +e
                    if command -v trivy > /dev/null 2>&1; then
                        trivy image --exit-code 0 --severity HIGH,CRITICAL \
                            --format table ${DOCKER_IMAGE}:${DOCKER_TAG}
                    else
                        echo "⚠️  Trivy not installed, skipping image scan."
                    fi
                    set -e
                """
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('📤 Push to Docker Hub') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                sh """
                    echo \$DOCKERHUB_PASS | docker login -u \$DOCKERHUB_USER --password-stdin
                    docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
                    docker push ${DOCKER_IMAGE}:latest
                    echo "✅ Pushed ${DOCKER_IMAGE}:${DOCKER_TAG} to Docker Hub"
                    docker logout
                """
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('☸️ Kubernetes Deploy') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh """
                        # Download kubectl if missing
                        if ! command -v kubectl > /dev/null 2>&1; then
                            echo "Installing kubectl..."
                            curl -LO "https://dl.k8s.io/release/v1.28.0/bin/linux/amd64/kubectl"
                            chmod +x kubectl
                            KUBECTL_CMD="./kubectl"
                        else
                            KUBECTL_CMD="kubectl"
                        fi

                        # Update manifest with correct tag
                        sed -i "s|IMAGE_TAG|${DOCKER_TAG}|g" devops/kubernetes/deployment.yaml

                        # Apply changes
                        \$KUBECTL_CMD --kubeconfig=\$KUBECONFIG apply -f devops/kubernetes/deployment.yaml
                        \$KUBECTL_CMD --kubeconfig=\$KUBECONFIG apply -f devops/kubernetes/service.yaml

                        echo "✅ Deployment successful"
                    """
                }
            }
        }
    }

    post {
        success {
            echo """
            ╔══════════════════════════════════════════╗
            ║  ✅ FinShield Pipeline SUCCESS            ║
            ║  Build #${env.BUILD_NUMBER} deployed      ║
            ╚══════════════════════════════════════════╝
            """
        }
        failure {
            echo "❌ Pipeline failed at stage. Check logs above."
        }
        always {
            sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} || true"
            cleanWs()
        }
    }
}
