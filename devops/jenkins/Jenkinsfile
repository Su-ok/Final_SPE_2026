// FinShield — Jenkins CI/CD Pipeline
// Triggers on GitHub push → Build → Test → Docker Push → Deploy

pipeline {
    agent any

    environment {
        APP_NAME        = "finshield-api"
        DOCKERHUB_USER  = "siddheshmahajan"
        DOCKER_TAG      = "${env.BUILD_NUMBER}"
        VAULT_ADDR      = "http://vault:8200"
        VAULT_TOKEN     = "finshield-root-token"
        KUBECONFIG_PATH = "/var/jenkins_home/.kube/config"
    }

    triggers {
        githubPush()
    }

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {

        // ─────────────────────────────────────────────────────────────────────
        stage('📥 Checkout') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                echo "🔍 Checking out source from GitHub..."
                checkout scm
                sh "git log --oneline -5"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('⚙️ Prepare Variables') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                script {
                    env.DOCKER_IMAGE = "${env.DOCKERHUB_USER}/${env.APP_NAME}"
                }
                echo "Docker Image: ${env.DOCKER_IMAGE}"
                echo "Docker Tag: ${env.DOCKER_TAG}"
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('🔐 Vault Secret Pull') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                sh """
                    echo "Fetching secrets from HashiCorp Vault..."
                    DOCKERHUB_PASS=\$(curl -s -H "X-Vault-Token: \$VAULT_TOKEN" \
                        \$VAULT_ADDR/v1/secret/data/finshield/dockerhub \
                        | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['data']['data']['password'])" 2>/dev/null || echo "")
                    echo "Vault secret pull complete ✅"
                """
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('🧪 Run Automated Tests') {

    steps {

        sh """

            cd app/backend

            # Create virtual environment
            python3 -m venv venv

            # Activate venv
            . venv/bin/activate

            # Upgrade pip
            pip install --upgrade pip

            # Install dependencies
            pip install -r requirements.txt

            pip install pytest httpx

            cd ../..

            # Run tests
            app/backend/venv/bin/python -m pytest \
                app/tests/ \
                -v \
                --tb=short \
                --junitxml=test-results.xml

        """
    }

    post {

        always {

            junit(
                allowEmptyResults: true,
                testResults: 'test-results.xml'
            )
        }

        failure {

            echo "❌ Tests failed! Aborting pipeline."
        }
    }
}

        // ─────────────────────────────────────────────────────────────────────
        stage('🐳 Build Docker Image') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                sh """
                    echo "Building Docker image: ${DOCKER_IMAGE}:${DOCKER_TAG}"
                    docker build \
                        --build-arg APP_VERSION=${DOCKER_TAG} \
                        -t ${DOCKER_IMAGE}:${DOCKER_TAG} \
                        -t ${DOCKER_IMAGE}:latest \
                        app/backend/
                    docker images | grep ${APP_NAME}
                """
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('🔒 Security Scan (Trivy)') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                sh """
                    set +e
                    if command -v trivy > /dev/null 2>&1; then
                        trivy image --exit-code 0 --severity HIGH,CRITICAL \
                            --format table ${DOCKER_IMAGE}:${DOCKER_TAG}
                    else
                        echo "⚠️  Trivy not installed, skipping image scan."
                    fi
                    set -e
                """
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        stage('📤 Push to Docker Hub') {
        // ─────────────────────────────────────────────────────────────────────
            steps {
                sh """
                    echo \$DOCKERHUB_PASS | docker login -u \$DOCKERHUB_USER --password-stdin
                    docker push ${DOCKER_IMAGE}:${DOCKER_TAG}
                    docker push ${DOCKER_IMAGE}:latest
                    echo "✅ Pushed ${DOCKER_IMAGE}:${DOCKER_TAG} to Docker Hub"
                    docker logout
                """
            }
        }
    }

    post {
        success {
            echo """
            ╔══════════════════════════════════════════╗
            ║  ✅ FinShield Pipeline SUCCESS            ║
            ║  Build #${env.BUILD_NUMBER} deployed      ║
            ╚══════════════════════════════════════════╝
            """
        }
        failure {
            echo "❌ Pipeline failed at stage. Check logs above."
        }
        always {
            sh "docker rmi ${DOCKER_IMAGE}:${DOCKER_TAG} || true"
            cleanWs()
        }
    }
}
